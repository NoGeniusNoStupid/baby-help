page {
  --bg-main: #fff7f2;
  --bg-card: #ffffff;
  --text-primary: #2f2a26;
  --text-secondary: #776b60;
  --accent: #ff8d6b;
  --accent-strong: #ff6f61;
  --line: #f2e6de;
  --shadow: 0 20rpx 48rpx rgba(255, 111, 97, 0.14);
  background: linear-gradient(180deg, #fff3ea 0%, #fff9f5 45%, #fffdfa 100%);
  color: var(--text-primary);
  min-height: 100%;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 168rpx;
  box-sizing: border-box;
}

.glass-card {
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(12rpx);
  border-radius: 28rpx;
  box-shadow: var(--shadow);
}

.primary-btn {
  background: linear-gradient(135deg, #ff8d6b 0%, #ff6f61 100%);
  color: #fff;
  border-radius: 999rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  padding: 26rpx 40rpx;
}

button::after {
  border: none;
}

.bottom-nav {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 999rpx;
  box-shadow: 0 20rpx 56rpx rgba(40, 20, 10, 0.12);
  padding: 12rpx;
  display: flex;
  z-index: 999;
}

.bottom-nav-item {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: #9a8f87;
  padding: 10rpx 0;
}

.bottom-nav-item.active {
  color: var(--accent-strong);
  font-weight: 600;
}
