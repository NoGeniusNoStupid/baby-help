.top-card {
  padding: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb790, #ff7a64);
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-main {
  flex: 1;
}

.name {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
}

.desc {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #88796e;
}

.stats {
  margin-top: 20rpx;
  padding: 20rpx;
  display: flex;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ff7359;
}

.label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8f8177;
}

.action {
  margin-top: 20rpx;
  padding: 26rpx;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.action-sub {
  display: block;
  margin-top: 10rpx;
  color: #8c7d72;
  font-size: 24rpx;
}

.action .primary-btn {
  margin-top: 22rpx;
}

.tools {
  margin-top: 20rpx;
  padding: 8rpx 20rpx;
}

.tool-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f5e8e0;
}

.tool-item:last-child {
  border-bottom: none;
}

.tool-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
}

.tool-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #938378;
}

.tool-arrow {
  font-size: 36rpx;
  color: #b8a79d;
}
