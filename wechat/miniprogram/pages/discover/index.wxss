.hero {
  padding: 30rpx;
  background: linear-gradient(135deg, #fff1e7, #ffffff);
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
}

.hero-sub {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #8b7a70;
  line-height: 1.7;
}

.hero-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.hero-btn {
  flex: 1;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1;
  padding: 20rpx 0;
}

.hero-btn.warm {
  border: none;
  color: #fff;
  background: linear-gradient(135deg, #ff916f, #ff6e60);
}

.hero-btn.light {
  border: 2rpx solid #ffd6c5;
  color: #aa6f5b;
  background: #fff;
}

.category-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-item {
  display: inline-block;
  font-size: 24rpx;
  color: #8d7f76;
  background: #fff;
  border: 2rpx solid #f6e4db;
  border-radius: 999rpx;
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
}

.category-active {
  color: #ff775f;
  border-color: #ffd2c3;
  background: #fff3ec;
}

.list-wrap {
  margin-top: 20rpx;
}

.card {
  margin-bottom: 18rpx;
  padding: 24rpx;
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
}

.score {
  font-size: 24rpx;
  color: #ff8368;
  background: #fff1ea;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

.card-meta {
  margin-top: 12rpx;
  display: block;
  font-size: 24rpx;
  color: #85786f;
}

.tag-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: #916f60;
  background: #fff8f3;
  border-radius: 12rpx;
  padding: 8rpx 14rpx;
}

.card-foot {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 30rpx;
  color: #ff7158;
  font-weight: 700;
}

.card-link {
  color: #ff7d67;
  font-size: 24rpx;
}
